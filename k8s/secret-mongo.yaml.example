# Copy to secret-mongo.yaml, set password (same as Terraform var db_admin_password), apply once:
#   cp k8s/secret-mongo.yaml.example k8s/secret-mongo.yaml
#   kubectl apply -f k8s/secret-mongo.yaml
# Do not commit secret-mongo.yaml with a real password.
apiVersion: v1
kind: Secret
metadata:
  name: todoiz-mongo
  namespace: todoiz
type: Opaque
stringData:
  password: "change-me"
